# ─────────────────────────────────────────────────────────────
# Art For Soul — environment variables
# Copy this file to ".env" (and add the same keys in Vercel → Settings → Environment Variables)
# ─────────────────────────────────────────────────────────────

# Public contact links (already in use)
NEXT_PUBLIC_WHATSAPP="+919834040231"
NEXT_PUBLIC_INSTAGRAM="https://www.instagram.com/artforsoul.in"

# ── Database (Supabase Postgres) ──
# Supabase → Project → Connect → ORMs/Prisma. Use the POOLED url for DATABASE_URL
# (port 6543, ?pgbouncer=true) and the DIRECT url for DIRECT_URL (port 5432).
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# ── Customer accounts (custom email + password auth) ──
# A long random secret used to sign login sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-string-32-chars-or-more"

# ── Razorpay (payments) ──
# razorpay.com → Settings → API Keys (use TEST keys first: rzp_test_...)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
